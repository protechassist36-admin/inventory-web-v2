generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// --- Global / Platform Models ---

model Business {
  id                  String            @id @default(cuid())
  name                String
  slug                String            @unique
  email               String?
  phone               String?
  address             String?
  logoUrl             String?
  type                BusinessType      @default(SHOP)
  plan                SubscriptionPlan  @default(FREE)
  status              String            @default("PENDING") // Changed default to PENDING
  registrationReceipt String? // Field for receipt upload/link
  trialStartDate      DateTime?         @default(now())
  trialEndDate        DateTime?
  enabledModules      String[]          @default([])
  currency            String            @default("SLL")
  timezone            String            @default("UTC")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  auditLogs           AuditLog[]
  categories          Category[]
  customers           Customer[]
  debts               Debt[]
  notifications       Notification[]
  products            Product[]
  purchases           Purchase[]
  purchaseItems       PurchaseItem[]
  restaurantTables    RestaurantTable[]
  sales               Sale[]
  saleItems           SaleItem[]
  stockMovements      StockMovement[]
  subscriptions       Subscription[]
  batches             Batch[] // Added opposite relation
  invoices            Invoice[]
  payments            Payment[]
  suppliers           Supplier[]
  users               User[]
  roles               Role[]
  expenses            Expense[]
  attendance          Attendance[]
  payrolls            Payroll[]
  loyaltyTiers        LoyaltyTier[]
  loyaltyCampaigns    LoyaltyCampaign[]
  orderStatusHistory  OrderStatusHistory[]
  
  flutterwaveRef      String?
  subscriptionStatus  String    @default("INACTIVE")

  @@index([slug])
}

model User {
  id                 String               @id @default(cuid())
  name               String?
  email              String               @unique
  passwordHash       String
  status             String               @default("active")
  emailVerified      DateTime?
  verificationToken  String?
  salary             Decimal?             @db.Decimal(10, 2)
  hourlyRate         Decimal?             @db.Decimal(10, 2)
  businessId         String
  roleId             String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?
  auditLogs          AuditLog[]
  purchases          Purchase[]
  sales              Sale[]
  stockMovements     StockMovement[]
  expenses           Expense[]
  attendance         Attendance[]
  payrolls           Payroll[]
  orderStatusHistory OrderStatusHistory[]
  business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role               Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([businessId])
  @@index([roleId])
  @@index([verificationToken])
}

model Attendance {
  id         String    @id @default(cuid())
  userId     String
  businessId String
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  status     String    @default("PRESENT") // e.g., "ON_TIME", "LATE", "ABSENT"
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Payroll {
  id            String    @id @default(cuid())
  userId        String
  businessId    String
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING") // PENDING, PAID
  periodStart   DateTime
  periodEnd     DateTime
  paymentDate   DateTime?
  paymentMethod String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  businessId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  business    Business?    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  permissions Permission[]
  users       User[]

  @@unique([businessId, name])
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique // e.g., "product:create"
  roles Role[]
}

// --- Tenant-Owned Models ---

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  businessId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId, deletedAt])
}

model Product {
  id                 String          @id @default(cuid())
  name               String
  sku                String?
  description        String?
  barcode            String?
  type               ProductType     @default(PRODUCT)
  unitPrice          Decimal         @db.Decimal(10, 2)
  costPrice          Decimal?        @db.Decimal(10, 2)
  stockQuantity      Int             @default(0)
  minStockLevel      Int             @default(10)
  status             String          @default("active")
  isNetworkAvailable Boolean         @default(false)
  originalProductId  String?
  originalBusinessId String?
  metadata           Json?
  businessId         String
  categoryId         String?
  imageUrl           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
  business           Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category           Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  batches            Batch[] // Added relation to batches
  purchaseItems      PurchaseItem[]
  saleItems          SaleItem[]
  stockMovements     StockMovement[]

  @@index([businessId, sku])
  @@index([businessId, deletedAt])
  @@index([isNetworkAvailable])
}

model Batch {
  id                String    @id @default(cuid())
  productId         String
  batchNumber       String
  quantity          Int       @default(0)
  manufacturingDate DateTime?
  expiryDate        DateTime?
  businessId        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([productId, batchNumber])
  @@index([businessId, expiryDate])
}

model RestaurantTable {
  id         String    @id @default(cuid())
  name       String
  capacity   Int       @default(4)
  status     String    @default("available")
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales      Sale[]

  @@unique([businessId, name])
  @@index([businessId, deletedAt])
}

model Customer {
  id         String    @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  debts      Debt[]
  sales      Sale[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Sale {
  id            String               @id @default(cuid())
  invoiceNumber String               @unique
  totalAmount   Decimal              @db.Decimal(10, 2)
  discount      Decimal              @default(0) @db.Decimal(10, 2)
  tax           Decimal              @default(0) @db.Decimal(10, 2)
  paymentMethod String               @default("CASH")
  paymentStatus String               @default("PAID")
  status        String               @default("COMPLETED")
  businessId    String
  userId        String
  customerId    String?
  tableId       String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?
  debt          Debt?
  statusHistory OrderStatusHistory[]
  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table         RestaurantTable?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  items         SaleItem[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  saleId     String
  status     String
  note       String?
  userId     String
  businessId String?
  createdAt  DateTime @default(now())

  sale     Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([businessId])
}

model SaleItem {
  id                 String   @id @default(cuid())
  saleId             String
  productId          String?
  productName        String? // Name for external or one-time items
  quantity           Int
  unitPrice          Decimal  @db.Decimal(10, 2)
  total              Decimal  @db.Decimal(10, 2)
  isExternalSourced  Boolean  @default(false)
  externalSourceName String?
  externalCostPrice  Decimal? @db.Decimal(10, 2)
  status             String   @default("pending")
  businessId         String?
  product            Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sale               Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  business           Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Supplier {
  id         String     @id @default(cuid())
  name       String
  contact    String?
  email      String?
  phone      String?
  businessId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  purchases  Purchase[]
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Purchase {
  id            String         @id @default(cuid())
  invoiceNumber String?
  totalAmount   Decimal        @db.Decimal(10, 2)
  status        String         @default("COMPLETED")
  supplierId    String?
  businessId    String
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  items         PurchaseItem[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitCost   Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  businessId String?
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model StockMovement {
  id         String            @id @default(cuid())
  productId  String
  quantity   Int
  type       StockMovementType
  reason     String?
  businessId String
  userId     String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([businessId, productId])
  @@index([businessId, deletedAt])
}

model Debt {
  id          String        @id @default(cuid())
  customerId  String
  saleId      String?       @unique
  totalAmount Decimal       @db.Decimal(10, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  dueDate     DateTime?
  status      String        @default("PENDING")
  businessId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale        Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)
  payments    DebtPayment[]

  @@index([businessId, customerId])
  @@index([businessId, deletedAt])
}

model DebtPayment {
  id            String    @id @default(cuid())
  debtId        String
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String    @default("CASH")
  note          String?
  businessId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  debt          Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([businessId, deletedAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  userId     String
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([businessId])
}

model Notification {
  id         String    @id @default(cuid())
  title      String
  message    String
  type       String    @default("INFO")
  isRead     Boolean   @default(false)
  businessId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Subscription {
  id         String           @id @default(cuid())
  businessId String
  plan       SubscriptionPlan
  status     String           @default("active")
  startDate  DateTime         @default(now())
  endDate    DateTime
  amount     Decimal          @db.Decimal(10, 2)
  currency   String           @default("SLL")
  paymentRef String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoyaltyTier {
  id          String   @id @default(cuid())
  name        String
  multiplier  Float
  discount    Float
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoyaltyCampaign {
  id            String   @id @default(cuid())
  name          String
  targetCluster String
  status        String   @default("DRAFT")
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Invoice {
  id         String    @id @default(cuid())
  businessId String
  amount     Decimal   @db.Decimal(10, 2)
  status     String    @default("UNPAID")
  dueDate    DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Payment {
  id            String    @id @default(cuid())
  businessId    String
  invoiceId     String
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String
  paymentRef    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, deletedAt])
}

model Expense {
  id            String    @id @default(cuid())
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  category      String // e.g., "Rent", "Utilities", "Salaries"
  date          DateTime  @default(now())
  paymentMethod String    @default("CASH")
  businessId    String
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([businessId])
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum BusinessType {
  SHOP
  RESTAURANT
  BAR
  PHARMACY
  SUPERMARKET
}

enum SubscriptionPlan {
  FREE
  BASIC
  STANDARD
  PREMIUM
}
